{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openbit.app/schemas/ui-foundation/slot.schema.json",
  "title": "SlotContractMap",
  "description": "Slot contracts for a catalog entry.",
  "$defs": {
    "NodeKind": {
      "type": "string",
      "enum": [
        "component",
        "fragment",
        "slot",
        "text",
        "collection"
      ]
    },
    "SlotContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "single",
            "collection"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "allowedKinds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/NodeKind"
          }
        },
        "allowedComponents": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*(\\.[a-z0-9][a-z0-9-]*)+$"
          }
        },
        "minItems": {
          "type": "integer",
          "minimum": 0
        },
        "maxItems": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  },
  "type": "object",
  "propertyNames": {
    "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
  },
  "additionalProperties": {
    "$ref": "#/$defs/SlotContract"
  }
}
