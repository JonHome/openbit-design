{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openbit.app/schemas/ui-foundation/prop-contract.schema.json",
  "title": "PropContractMap",
  "description": "Declarative prop contracts for catalog entries.",
  "$defs": {
    "ScalarDefault": {
      "type": [
        "string",
        "number",
        "boolean",
        "null"
      ]
    },
    "PropContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "string",
            "number",
            "boolean",
            "enum",
            "object",
            "array"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        },
        "enum": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/ScalarDefault"
          }
        },
        "default": {
          "oneOf": [
            {
              "$ref": "#/$defs/ScalarDefault"
            },
            {
              "type": "array"
            },
            {
              "type": "object"
            }
          ]
        },
        "items": {
          "$ref": "#/$defs/PropContract"
        },
        "properties": {
          "type": "object",
          "propertyNames": {
            "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
          },
          "additionalProperties": {
            "$ref": "#/$defs/PropContract"
          }
        }
      }
    }
  },
  "type": "object",
  "propertyNames": {
    "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
  },
  "additionalProperties": {
    "$ref": "#/$defs/PropContract"
  }
}
