{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openbit.app/schemas/ui-foundation/variant.schema.json",
  "title": "VariantContractMap",
  "description": "Allowed variants for a catalog entry or preset.",
  "$defs": {
    "VariantValue": {
      "type": [
        "string",
        "number",
        "boolean"
      ]
    }
  },
  "type": "object",
  "propertyNames": {
    "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
  },
  "additionalProperties": {
    "type": "array",
    "minItems": 1,
    "uniqueItems": true,
    "items": {
      "$ref": "#/$defs/VariantValue"
    }
  }
}
